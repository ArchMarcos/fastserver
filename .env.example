# ==========================================
# FastDelivery — Environment Variables
# Copie este arquivo para .env e preencha
#   cp .env.example .env
# ==========================================

# ── Database (PortunusDB) ──
DATABASE_HOST=http://0.0.0.0:3100
DATABASE_USER=root
DATABASE_PASSWORD=0077
DATABASE_NAME=FD2

# ── JWT ──
JWT_SECRET_KEY=super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_EMAIL_EXPIRE_MINUTES=60

# ── Server ──
SERVER_HOST=0.0.0.0
SERVER_PORT=3101
DEBUG=true

# ── App URL (usado nos links dos emails) ──
# APP_URL=http://localhost:3101

# ── Logging ──
LOG_LEVEL=DEBUG
LOG_FILE=logs/app.log

# ── Email (opcional — deixe vazio para modo simulação) ──
# Gmail:     smtp.gmail.com    / precisa de App Password (https://myaccount.google.com/apppasswords)
# Outlook:   smtp-mail.outlook.com
# Yahoo:     smtp.mail.yahoo.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@fastdelivery.com

# ── Platform ──
PLATFORM_TAX=0.05
PLATFORM_NAME=FastDelivery
